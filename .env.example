# Canonical site origin (no trailing slash). Required for real production deploys
# (local `next dev` defaults to http://localhost:3000; Vercel may use VERCEL_URL if unset).
# In production, set both to the same HTTPS apex (server/cron/scripts read SITE_URL; browser bundle uses NEXT_PUBLIC_*).
SITE_URL=https://toollabz.com
NEXT_PUBLIC_SITE_URL=https://toollabz.com

# --- Optional / feature-specific (replace placeholders; never commit real secrets) ---
OPENAI_API_KEY=your_key
CONTENT_ENGINE_SECRET=your_random_secret
TOOLLABZ_SEO_CONSOLE_SECRET=your_console_secret
# CONTENT_ENGINE_SECRET doubles as x-toollabz-secret auth (or set CRON_SECRET to the same value).

# Preflight before deploy:
#   npm run preflight
# Strict production check + build:
#   NEXT_PUBLIC_SITE_URL=https://your-domain.com npm run preflight:ci

# Google Analytics 4 — Measurement ID from GA Admin → Data streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console — HTML tag verification content value only (not the full meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense — publisher ID (ca-pub-xxxxxxxxxxxxxxxx)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Optional: POST URL for Core Web Vitals (see WebVitalsReporter)
# NEXT_PUBLIC_WEB_VITALS_ENDPOINT=
